<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/trend_ranking_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_surface_background"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="@string/widget_rankings_title"
            android:textColor="#FF111827"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/trend_ranking_updated_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_rankings_loading"
            android:textColor="#FF6B7280"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/trend_rankings_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/widget_rankings_empty"
        android:textColor="#FF6B7280"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/trend_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/widget_ranking_row_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/trend_rank_1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_cta_background"
            android:gravity="center"
            android:textColor="#FF4C1D95"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/trend_name_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trend_meta_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF6B7280"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/trend_delta_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/trend_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_ranking_row_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/trend_rank_2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_cta_background"
            android:gravity="center"
            android:textColor="#FF4C1D95"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/trend_name_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trend_meta_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF6B7280"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/trend_delta_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/trend_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_ranking_row_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/trend_rank_3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_cta_background"
            android:gravity="center"
            android:textColor="#FF4C1D95"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/trend_name_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trend_meta_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF6B7280"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/trend_delta_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
